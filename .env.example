# Servizio email per i form di contatto e preventivo
# Valori possibili: "console" (dev, logga in console) | "resend" (produzione)
EMAIL_SERVICE=console

# Destinatario delle email (form contatto + preventivo)
EMAIL_TO=info@amcovr.it

# Mittente delle email
EMAIL_FROM=noreply@amcovr.it

# API Key di Resend (obbligatoria se EMAIL_SERVICE=resend)
# Registrati su https://resend.com e ottieni la chiave
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
